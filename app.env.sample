# YOURLS - app.env.sample
# Copy to app.env and adjust values before starting

# Timezone
TZ=America/New_York

# Hostname / domain
BASE_HOST_NAME=$HOSTNAME
BASE_DOMAIN_NAME=example.com

# Database credentials
DB_CREATE_DATABASE_NAME=yourls
DB_USER_NAME=yourls
DB_USER_PASS=changeme_db_password
DB_ADMIN_PASS=changeme_admin_password

# Admin user
APP_ADMIN_USER=administrator
APP_ADMIN_PASS=changeme_admin_password
